## Common Patterns

### Server-side data fetching (Student dashboard)
```tsx
// app/student/page.tsx
import { createClient } from '@/lib/supabase/server';

export default async function StudentDashboard() {
  const supabase = createClient();
  const { data: { user } } = await supabase.auth.getUser();
  const { data: enrollments } = await supabase
    .from('enrollments')
    .select('*, courses(*), lessons(*)')
    .eq('student_id', user.id);

  return <Dashboard enrollments={enrollments} />;
}
```

### Triggering an SMS
```ts
import { triggerSms } from '@/lib/sms';

await triggerSms({
  userId: parentId,
  event: 'homework_assigned',
  data: { studentName, courseName, dueDate, link }
});
```

### Uploading homework
```ts
const { data, error } = await supabase.storage
  .from('homework-submissions')
  .upload(`${studentId}/${homeworkId}/${file.name}`, file);
```
